###############################################################################
# Pa_mSikA — Environment Variables EXAMPLE
# Copy this to .env and fill in real values before deploying.
###############################################################################

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development   # change to "production" when live

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pamsika
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=pamsika_db

DATABASE_URL=postgresql://pamsika:CHANGE_ME_strong_password@db:5432/pamsika_db
DATABASE_URL_ASYNC=postgresql+asyncpg://pamsika:CHANGE_ME_strong_password@db:5432/pamsika_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
USE_REDIS=false

# ── JWT & Security ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_hex_string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ADMIN_TOKEN_EXPIRE_MINUTES=480

# Generate with: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes

# ── CORS ──────────────────────────────────────────────────────────────────────
# ⚠️  IMPORTANT: Add your real domain here or login/signup will fail in production
#     with a CORS error in the browser console.
ALLOWED_ORIGINS=["http://localhost","http://127.0.0.1","https://yourdomain.com","https://www.yourdomain.com"]
ALLOWED_HOSTS=["*"]

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Cookies ───────────────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true in production (requires HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
